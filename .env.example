# Predictic Match - Environment Variables
# Copy this file to .env and fill in your values

# Data Paths
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_MODELS_PATH=data/models

# Output Paths
OUTPUT_PREDICTIONS_PATH=output/predictions
OUTPUT_REPORTS_PATH=output/reports
OUTPUT_PLOTS_PATH=output/plots

# Football Data Configuration
# Available leagues: E0 (Premier League), SP1 (La Liga), I1 (Serie A), D1 (Bundesliga), F1 (Ligue 1)
DEFAULT_LEAGUE=E0
SEASONS_START=2018
SEASONS_END=2024

# Model Configuration
TEST_SIZE=0.2
RANDOM_STATE=42
CV_FOLDS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/predictic_match.log

# Optional: API Keys (if using external services)
# API_KEY=your_api_key_here
